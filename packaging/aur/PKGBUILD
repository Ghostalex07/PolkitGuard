pkgname=polkitguard
pkgver=1.3.0
pkgrel=1
arch=('x86_64')
license=('MIT')
provides=('polkitguard')
source=("polkitguard-${pkgver}.tar.gz")
md5sums=('SKIP')

package() {
  cd "${pkgdir}"
  install -Dm755 polkitguard "${pkgdir}/usr/bin/polkitguard"
  install -Dm644 ../config.schema.json "${pkgdir}/usr/share/polkitguard/config.schema.json"
}

post_install() {
  echo "PolkitGuard installed. Run 'polkitguard --help' for usage."
}