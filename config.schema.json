{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PolkitGuard Configuration",
  "type": "object",
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\.[0-9]+$"
    },
    "severity_filter": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "output_format": {
      "type": "string",
      "enum": ["text", "json", "html", "sarif", "csv"]
    },
    "custom_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "exclude_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "enable_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "ignore_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "custom_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string" },
          "description": { "type": "string" },
          "pattern": { "type": "string" },
          "message": { "type": "string" },
          "impact": { "type": "string" },
          "recommendation": { "type": "string" }
        },
        "required": ["id", "severity", "pattern"]
      }
    },
    "verbose": { "type": "boolean" },
    "quiet": { "type": "boolean" }
  }
}